PORT=3002
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://localhost:5432/haulbook

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string

# App URL (for OAuth callbacks, email links)
APP_URL=http://localhost:3002

# Stripe
STRIPE_SECRET_KEY=sk_test_YOUR_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET
STRIPE_PRICE_PRO=price_YOUR_PRO_ID
STRIPE_PRICE_BUSINESS=price_YOUR_BUSINESS_ID

# Anthropic (receipt scanning)
ANTHROPIC_API_KEY=your_anthropic_api_key
